{
  "name": "setup-emsdk",
  "version": "1.0.3",
  "private": true,
  "type": "module",
  "description": "Github action to download and setup Emscripten",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && ncc build lib/main.js --license licenses.txt -m --target es2022",
    "test:compile": "tsc -p tsconfig.ava.json",
    "test": "pnpm run test:compile && ava"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/actions/node12-template.git"
  },
  "keywords": [
    "actions",
    "node",
    "setup"
  ],
  "author": "mymindstorm",
  "license": "MIT",
  "dependencies": {
    "@actions/core": "^3.0.0",
    "@actions/exec": "^3.0.0",
    "@actions/io": "^3.0.2",
    "@actions/tool-cache": "^4.0.0"
  },
  "devDependencies": {
    "@ava/typescript": "^6.0.0",
    "@types/node": "^25.5.0",
    "@vercel/ncc": "^0.38.4",
    "ava": "^7.0.0",
    "typescript": "^5.9.3"
  },
  "ava": {
    "typescript": {
      "compile": false,
      "rewritePaths": {
        "test/": ".ava/test/"
      }
    }
  }
}
